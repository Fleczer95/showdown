{
  "expo": {
    "name": "ShowDown",
    "slug": "showdown",
    "version": "1.0.1",
    "scheme": "showdown",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#1A1A2E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.showdown.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "associatedDomains": [
        "applinks:showdown.lebene.pl"
      ],
      "infoPlist": {
        "CFBundleName": "ShowDown"
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.showdown.app",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "com.android.vending.BILLING"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "monochromeImage": "./assets/icon.png",
        "backgroundColor": "#1A1A2E"
      },
      "versionCode": 22,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "showdown.lebene.pl",
              "pathPrefix": "/c"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-localization",
      "@react-native-firebase/app",
      "@react-native-firebase/app-check",
      "expo-audio",
      "expo-asset"
    ],
    "extra": {
      "sentryDsn": "https://8cacf301cd3ad357974428f5e981422a@o4510449415553024.ingest.de.sentry.io/4511477176926288"
    }
  }
}
