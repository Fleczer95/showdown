rules_version = '2';

// Security rules for the Async Challenge (ADR-0003).
//
// Identity is a device UUID with no auth, so the rules — not a server — are what
// keep challenges honest: the challenge document is immutable after create, and
// each device may write exactly one attempt that it can never alter. This is the
// strongest guarantee available without sign-in (dedup is honour-based: it stops
// casual double-attempts, not a determined cheat).
service cloud.firestore {
  match /databases/{database}/documents {

    function isValidChallenge(d) {
      return d.keys().hasOnly(['lang', 'game', 'questions', 'createdBy', 'expiresAt'])
        && d.lang in ['en', 'pl']
        && d.game is string && d.game.size() <= 40
        && d.questions is list && d.questions.size() > 0 && d.questions.size() <= 50
        && d.createdBy is map
        && d.createdBy.uuid is string && d.createdBy.uuid.size() <= 64
        && d.createdBy.nickname is string && d.createdBy.nickname.size() <= 24
        && d.expiresAt is timestamp
        // Bound the lifetime so a client can't create a near-immortal doc; 31d
        // leaves a day of slack over the app's 30d TTL for client/server clock skew.
        && d.expiresAt < request.time + duration.value(31, 'd');
    }

    function isValidAttempt(d) {
      return d.keys().hasOnly(['nickname', 'progress', 'score', 'timestamp'])
        && d.nickname is string && d.nickname.size() <= 24
        && d.progress is int
        && d.score is number
        && d.timestamp is int;
    }

    // --- Global ranking (ADR-0004) ---
    // A per-game, score-only bounded leaderboard. Public read; a device writes
    // only its own {uuid} entry; updates may only raise the score (best-only);
    // clients never delete (rotation/retention is the Admin-SDK cleanup script).
    // `signature` is an optional, system-derived earned-cosmetic slug. It is never
    // user input (the app computes it from the player's level), so it must be one of
    // the known slugs — keep this list in sync with SIGNATURE_SLUGS in
    // src/game/progression/signatures.ts. A modified client could still write a
    // valid-but-unearned slug (pure vanity, unverifiable without a server); the
    // Admin-SDK cleanup `--remove` is the backstop. Nicknames stay text-only.
    function isValidRankingEntry(d) {
      return d.keys().hasOnly(['nickname', 'score', 'signature'])
        && d.nickname is string && d.nickname.size() > 0 && d.nickname.size() <= 24
        && d.score is number && d.score >= 0 && d.score <= 1000000000
        && (!('signature' in d)
            || d.signature in ['sprout', 'spark', 'fire', 'gem', 'star', 'crown']);
    }
    function isRankedGame(game) {
      return game in ['the-ladder', 'the-drop', 'the-wheel'];
    }
    // The server clock decides the month: a month bucket's UTC YYYY-MM must equal
    // request.time, so a tampered device clock can't write into another month.
    // 'alltime' is always writable (it never resets).
    function isWritablePeriod(period) {
      return period == 'alltime'
        || (period.size() == 7
            && int(period[0:4]) == request.time.year()
            && int(period[5:7]) == request.time.month());
    }

    match /rankings/{game}/periods/{period}/entries/{uuid} {
      allow read: if true;
      allow create: if isRankedGame(game) && isWritablePeriod(period)
        && isValidRankingEntry(request.resource.data);
      // Best-only: an update may never lower the stored score. `>=` (not `>`) so a
      // device re-asserting its own unchanged best is idempotent — a strict `>`
      // turns that harmless re-push into a permanent permission-denied retry storm.
      allow update: if isRankedGame(game) && isWritablePeriod(period)
        && isValidRankingEntry(request.resource.data)
        && request.resource.data.score >= resource.data.score;
      allow delete: if false;
    }

    match /c/{challengeId} {
      // Anyone with the link may read and create; the round is immutable after.
      allow read: if true;
      allow create: if isValidChallenge(request.resource.data);
      allow update, delete: if false;

      match /attempts/{uuid} {
        allow read: if true;
        // One attempt per device UUID, create-only, validated, never mutated, and
        // only under a challenge that actually exists — no orphan attempts.
        allow create: if isValidAttempt(request.resource.data)
          && exists(/databases/$(database)/documents/c/$(challengeId))
          && !exists(/databases/$(database)/documents/c/$(challengeId)/attempts/$(uuid));
        allow update, delete: if false;
      }
    }

    // Default-deny everything outside the challenge tree.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
