<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application>
        <!-- Play Games Services project id — merged into the app manifest so the
             hand-edited app AndroidManifest.xml (see AGENTS.md) stays untouched.
             The value lives in res/values/games-ids.xml (filled by provisioning). -->
        <meta-data
            android:name="com.google.android.gms.games.APP_ID"
            android:value="@string/game_services_project_id" />
    </application>
</manifest>
