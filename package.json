{
  "name": "showdown",
  "main": "node_modules/expo/AppEntry.js",
  "version": "1.3.0",
  "type": "module",
  "scripts": {
    "android": "expo run:android",
    "ios": "expo run:ios",
    "start": "expo start --tunnel",
    "dev": "node scripts/fix-line-endings.js scripts/dev.sh && ./scripts/dev.sh",
    "version": "node scripts/bump-version.js",
    "dependency-fix": "npx expo install --check",
    "lint": "expo lint",
    "lint:fix": "expo lint --fix",
    "lint:format": "npm run lint:fix && npm run format",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "doctor": "npx expo-doctor",
    "static": "npm run type-check && npm run lint && npm run format:check",
    "i18n:check": "node scripts/analyze-translations.js",
    "challenges:cleanup": "node scripts/cleanup-expired-challenges.mjs",
    "test": "jest",
    "test:watch": "jest --watch",
    "prebuild": "node scripts/prebuild.js",
    "aab": "rm -rf android/app/build android/.gradle android/build android/app/.cxx && npx expo prebuild --platform android --no-install && npm run prebuild && npx react-native build-android --mode=release",
    "bundletool": "scripts/bundletool.sh"
  },
  "dependencies": {
    "@expo-google-fonts/fredoka": "^0.4.1",
    "@expo-google-fonts/inter": "^0.4.2",
    "@react-native-firebase/analytics": "^24.0.0",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-firebase/app-check": "^24.0.0",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.12",
    "@sentry/react-native": "~7.2.0",
    "@shopify/react-native-skia": "2.2.12",
    "@xstate/react": "^6.1.0",
    "expo": "~54.0.34",
    "expo-asset": "~12.0.13",
    "expo-audio": "~1.1.1",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-haptics": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-localization": "~17.0.8",
    "expo-sensors": "~15.0.8",
    "expo-status-bar": "~3.0.8",
    "expo-store-review": "~9.0.9",
    "expo-system-ui": "~6.0.8",
    "i18n-js": "^4.5.3",
    "lodash": "^4.18.1",
    "lucide-react-native": "^1.14.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-iap": "^14.4.46",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.6",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1",
    "xstate": "^5.32.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@react-native-community/cli": "^20.1.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.10",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "firebase-admin": "^14.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "prettier": "^3.6.2",
    "react-test-renderer": "^19.1.0",
    "ts-jest": "^29.4.9",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=20.19.4"
  },
  "private": true
}
