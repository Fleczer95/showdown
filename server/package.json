{
  "name": "showdown-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types",
    "schema:remote": "wrangler d1 execute showdown_db --remote --file=./schema.sql",
    "schema:local": "wrangler d1 execute showdown_db --local --file=./schema.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250601.0",
    "typescript": "^5.9.2",
    "wrangler": "^4.0.0"
  }
}
